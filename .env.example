# Dev: set to 1 to show the full-screen ignition sequence (default = skipped in dev for faster HMR)
VITE_DEV_IGNITION=

# Optional hero background (home / paddock)
# MP4: progressive file — dual-layer seamless crossfade in `FadingVideo`
VITE_HERO_VIDEO_MP4=

# HLS: m3u8 URL — uses hls.js (Safari can use native HLS)
VITE_HERO_VIDEO_HLS=
